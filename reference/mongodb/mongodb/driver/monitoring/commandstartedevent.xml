  <section xml:id="mongodb-driver-monitoring-commandstartedevent.intro">
   &reftitle.intro;
   <simpara>
    The <classname>MongoDB\Driver\Monitoring\CommandStartedEvent</classname>
    class encapsulates information about a started command.
   </simpara>
  </section>
<!-- }}} -->

