  <section xml:id="mongodb-driver-monitoring-commandfailedevent.intro">
   &reftitle.intro;
   <simpara>
    The <classname>MongoDB\Driver\Monitoring\CommandFailedEvent</classname>
    class encapsulates information about a failed command.
   </simpara>
  </section>
<!-- }}} -->

