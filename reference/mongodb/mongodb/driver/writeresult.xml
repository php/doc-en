 <partintro>

<!-- {{{ MongoDB\Driver\WriteResult intro -->
  <section xml:id="mongodb-driver-writeresult.intro">
   &reftitle.intro;
   <simpara>
    The <classname>MongoDB\Driver\WriteResult</classname> class encapsulates
    information about an executed
    <classname>MongoDB\Driver\BulkWrite</classname> and may be returned by
    <methodname>MongoDB\Driver\Manager::executeBulkWrite</methodname>.

   </simpara>
  </section>
<!-- }}} -->

