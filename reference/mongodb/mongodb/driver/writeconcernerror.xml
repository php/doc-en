 <partintro>

<!-- {{{ MongoDB\Driver\WriteConcernError intro -->
  <section xml:id="mongodb-driver-writeconcernerror.intro">
   &reftitle.intro;
   <simpara>
    The <classname>MongoDB\Driver\WriteConcernError</classname> class
    encapsulates information about a write concern error and may be returned by
    <methodname>MongoDB\Driver\WriteResult::getWriteConcernError</methodname>.
   </simpara>
  </section>
<!-- }}} -->

