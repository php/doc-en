<refentry xml:id="ds-heap.pop" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Ds\Heap::pop</refname>
  <refpurpose>Removes and returns the value at the top of the heap</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>mixed</type><methodname>Ds\Heap::pop</methodname>
   <void />
  </methodsynopsis>
  <para>
   Removes and returns the value at the top of the heap.
  </para>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <para>
   The removed value which was at the top of the heap.
  </para>
 </refsect1>

 <refsect1 role="errors">
  &reftitle.errors;
  <para>
   <classname>UnderflowException</classname> if empty.
  </para>
 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <example>
   <title><function>Ds\Heap::pop</function> example</title>
   <programlisting role="php">
<![CDATA[
<?php
$heap = new \Ds\Heap();

$heap->push(5);
$heap->push(1);
$heap->push(3);

print_r($heap->pop());
print_r($heap->pop());
print_r($heap->pop());
?>
]]>
   </programlisting>
   &example.outputs.similar;
   <screen>
<![CDATA[
int(5)
int(3)
int(1)
]]>
   </screen>
  </example>
 </refsect1>


</refentry>

