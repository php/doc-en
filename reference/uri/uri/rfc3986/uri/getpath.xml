<?xml version="1.0" encoding="utf-8"?>
<refentry xml:id="uri-rfc3986-uri.getpath" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Uri\Rfc3986\Uri::getPath</refname>
  <refpurpose>Retrieve the normalized path component</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis role="Uri\\Rfc3986\\Uri">
   <modifier>public</modifier> <type>string</type><methodname>Uri\Rfc3986\Uri::getPath</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Retrieves the normalized path component.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Returns the normalized path component as a &string;.
  </simpara>
 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <example xml:id="uri-rfc3986-uri.getpath.example.basic">
   <title><methodname>Uri\Rfc3986\Uri::getPath</methodname> basic example</title>
   <programlisting role="php">
<![CDATA[
<?php

$uri = new \Uri\Rfc3986\Uri('HTTPS://p%68p:elephp%61nt@WWW.PHP.NET:443/manual/ch%61nge.php?p%61ge=en/book.uri.php#%62ook.uri');

var_dump($uri->getPath());

?>
]]>
   </programlisting>
   &example.outputs;
   <screen>
<![CDATA[
string(18) "/manual/change.php"
]]>
   </screen>
  </example>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>Uri\Rfc3986\Uri::getRawPath</methodname></member>
   <member><methodname>Uri\Rfc3986\Uri::withPath</methodname></member>
   <member><methodname>Uri\WhatWg\Url::getPath</methodname></member>
  </simplelist>
 </refsect1>
</refentry>
